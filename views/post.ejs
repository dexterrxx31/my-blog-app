<%- include("partials/head", { title: post.title + " — Daily Journal", metaDescription: post.excerpt }) %>
<%- include("partials/nav") %>

<div class="progress-bar" aria-hidden="true"></div>
<article class="article">
  <div class="article-topbar">
    <a href="/" class="back-link">← All posts</a>
  </div>
  <header class="article-header">
    <% if (post.tags && post.tags.length) { %>
      <div class="tag-row center">
        <% post.tags.forEach(function (tag) { %>
          <a href="/tag/<%= tag.slug %>" class="tag-pill"><%= tag.name %></a>
        <% }); %>
      </div>
    <% } %>
    <h1 class="article-title"><%= post.title %></h1>
    <div class="article-meta">
      <time datetime="<%= post.created_at %>"><%= new Date(post.created_at.replace(" ", "T") + "Z").toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) %></time>
      <span aria-hidden="true">·</span>
      <span><%= post.reading_time %> min read</span>
    </div>
    <% if (isAuthed) { %>
      <div class="article-admin">
        <a href="/admin/edit/<%= post.id %>" class="btn btn-ghost btn-sm">Edit</a>
        <form action="/admin/delete/<%= post.id %>" method="POST" class="inline-form"
              onsubmit="return confirm('Delete this post permanently?');">
          <button type="submit" class="btn btn-danger btn-sm">Delete</button>
        </form>
      </div>
    <% } %>
  </header>

  <% if (post.cover_image_url) { %>
    <figure class="article-cover">
      <img src="<%= post.cover_image_url %>" alt="">
    </figure>
  <% } %>

  <div class="prose">
    <%- post.html %>
  </div>
</article>

<%- include("partials/footer") %>
