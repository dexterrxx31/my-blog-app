      <a href="/contact" class="nav-link <%= currentPath === "/contact" ? "active" : "" %>" <%- currentPath === "/contact" ? 'aria-current="page"' : "" %>>Contact</a>
    </div>

    <div class="nav-actions">
      <form action="/search" method="GET" class="search-form" role="search">
